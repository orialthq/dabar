{
  "name": "dabar",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:desktop": "tsc -b && vite build --base=/ --outDir dist-desktop",
    "desktop": "npm run build:desktop && electron .",
    "dist:mac": "npm run build:desktop && electron-builder --mac",
    "dist:win": "npm run build:desktop && electron-builder --win"
  },
  "dependencies": {
    "electron-serve": "^3.0.1"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "dev.orialt.dabar",
    "productName": "Dabar",
    "artifactName": "dabar-${version}-${os}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "orialthq",
      "repo": "dabar"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "dist-desktop/**",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.lifestyle",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
